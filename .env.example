# Copy to `.env` and adjust as needed. All variables are optional and fall
# back to the defaults defined in src/financial_sentiment/config/settings.py.
# Environment variables are prefixed with FIN_ and override the YAML config.

# --- Data ---
FIN_DATA_PATH=data.csv
FIN_TEXT_COLUMN=Sentence
FIN_LABEL_COLUMN=Sentiment

# --- Reproducibility ---
FIN_RANDOM_SEED=42

# --- Output locations ---
FIN_OUTPUT_DIR=outputs

# --- Transformer training (optional) ---
FIN_MODEL_CHECKPOINT=roberta-base
FIN_EPOCHS=5
FIN_TRAIN_BATCH_SIZE=32
FIN_LR=3e-5
